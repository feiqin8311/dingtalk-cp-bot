# DingTalk credentials (Stream + robot send)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_ROBOT_CODE=
# 技术告警接收人（多个用英文逗号分隔）
DING_TECH_USER_IDS=

# Optional aliases for Stream client
CLIENT_ID=
CLIENT_SECRET=

# LingXing OpenAPI
LINGXING_API_HOST=http://121.41.4.126:3188
LINGXING_API_KEY=
LINGXING_API_SECRET=
LINGXING_TOKEN_URL=http://121.41.4.126:3721/token
LINGXING_TOKEN_REQUEST_KEY=
LINGXING_SSL_VERIFY=false

# Aliyun OCR
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# Optional alternative keys
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# Optional
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com

# Local storage
DOWNLOAD_DIR=downloads
ADDRESS_BOOK_XLSX_PATH=files/全站点地址.xlsx

# DB state store (dedup + shipment locks + request logs)
# Note: tables are created manually via sql/mysql_state.sql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dingtalk_cp_bot
DB_CONNECT_TIMEOUT_SEC=5

# Docker compose host path for Common repo (used by volume mount)
COMMON_DIR=
# Logging
LOG_LEVEL=INFO
